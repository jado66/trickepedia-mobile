{
  "cli": {
    "version": ">= 18.7.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": true,
        "resourceClass": "m-large"
      },
      "android": {
        "buildType": "apk",
        "resourceClass": "large"
      },
      "cache": {
        "key": "v1",
        "paths": [
          "node_modules/**/*",
          "ios/Pods/**/*",
          "~/.gradle/caches/**/*",
          "~/Library/Caches/CocoaPods/**/*"
        ]
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-large"
      },
      "android": {
        "resourceClass": "large"
      },
      "cache": {
        "key": "v1",
        "paths": [
          "node_modules/**/*",
          "ios/Pods/**/*",
          "~/.gradle/caches/**/*",
          "~/Library/Caches/CocoaPods/**/*"
        ]
      }
    }
  },
  "submit": {
    "production": {}
  }
}
