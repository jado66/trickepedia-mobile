# Copy this file to `.env` and fill in the values.
# Variables prefixed with EXPO_PUBLIC_ are inlined into the client bundle
# by the Expo / Metro bundler and are safe to expose (they're public anyway).

# Same Supabase project as the web app (trickepedia).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
